            }
          ]
        ],
        "node_holes": [],
        "nodes": [
          {
            "Solvable": 0,
            "display": "<root>"
          },
          {
            "UnresolvedDependency": null,
            "display": "unresolved dependency"
          }
        ]
      },
      "root_node": 0,
      "unresolved_node": 1
    }
  },
  "title": "Resolvo Machine-Readable Error Examples"
